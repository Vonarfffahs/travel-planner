<html lang='en'>
  <head>
    <meta charset='UTF-8' />
    <meta name='viewport' content='width=device-width, initial-scale=1.0' />
    <title>Confirm Your Account And Create Your Password</title>
  </head>
  <body
    style='margin: 0; padding: 0; background-color: #f4f4f4; font-family: Arial, Helvetica, sans-serif; -webkit-font-smoothing: antialiased;'
  >
    <table
      role='presentation'
      border='0'
      cellpadding='0'
      cellspacing='0'
      width='100%'
      style='background-color: #f4f4f4; padding: 40px 20px;'
    >
      <tr>
        <td align='center'>
          <table
            role='presentation'
            border='0'
            cellpadding='0'
            cellspacing='0'
            width='600'
            style='background-color: #ffffff; border-radius: 8px; overflow: hidden; max-width: 600px; width: 100%; border: 1px solid #e0e0e0;'
          >
            <tr>
              <td style='padding: 40px 30px; text-align: left; color: #333333;'>

                <h2
                  style='margin-top: 0; margin-bottom: 20px; color: #1a2f16; font-size: 24px;'
                >
                  Welcome,
                  {{nickname}}!
                </h2>

                <p
                  style='font-size: 16px; line-height: 1.6; margin-bottom: 24px; margin-top: 0;'
                >
                  Thank you for joining us. To complete your registration and
                  log in, please confirm your email address and create a secure
                  password.
                </p>

                <table
                  role='presentation'
                  border='0'
                  cellpadding='0'
                  cellspacing='0'
                  style='margin-bottom: 24px;'
                >
                  <tr>
                    <td
                      align='center'
                      bgcolor='#c7eabb'
                      style='border-radius: 6px;'
                    >
                      <a
                        href='{{link}}'
                        style='display: inline-block; padding: 14px 28px; color: #1a2f16; text-decoration: none; font-size: 16px; font-weight: bold; border: 1px solid #c7eabb; border-radius: 6px;'
                      >
                        Create Password
                      </a>
                    </td>
                  </tr>
                </table>

                <table
                  role='presentation'
                  border='0'
                  cellpadding='0'
                  cellspacing='0'
                  width='100%'
                  style='background-color: #fff8e1; border-left: 4px solid #ffc107; margin-bottom: 24px;'
                >
                  <tr>
                    <td style='padding: 12px 16px;'>
                      <p
                        style='margin: 0; font-size: 14px; line-height: 1.5; color: #664d03;'
                      >
                        <strong>⚠️ Important:</strong>
                        This setup link is valid until
                        <strong>{{expirationDate}}</strong>. After that, you
                        will need to request a new one.
                      </p>
                    </td>
                  </tr>
                </table>

                <table
                  role='presentation'
                  border='0'
                  cellpadding='0'
                  cellspacing='0'
                  width='100%'
                  style='margin: 30px 0;'
                >
                  <tr>
                    <td style='border-top: 1px solid #eeeeee;'></td>
                  </tr>
                </table>

                <p
                  style='font-size: 14px; color: #999999; margin: 0; line-height: 1.5;'
                >
                  If you did not request this email, please safely ignore it.
                  <br /><br />
                  Best regards,<br />
                  <strong>The Trip Planner Team</strong>
                </p>

              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>